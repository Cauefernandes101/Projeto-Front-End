<!DOCTYPE html>
<html lang="pt-br">
<head>
  <link rel="stylesheet" href="https://use.typekit.net/fcd8hzk.css">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lista de Livros</title>
  <link rel="stylesheet" href="estilo.css">
</head>
<body>

<header class="header">
  <div class="logo" >
    <img src="imagens\Captura de tela 2026-05-07 174437.png" width="80" height="80">
    <h1>Estante Pública</h1>
  </div>
  <div class="header-right">
    <div class="search-container">
      <input type="text" class="search" id="inputLivro" placeholder="Digite o nome do livro..." autocomplete="off">
      <div id="listaSugestoes" class="sugestoes"></div>
    </div>
    <img src="https://i.pinimg.com/564x/c7/ab/cd/c7abcd3ce378191a3dddfa4cdb2be46f.jpg" alt="Smiley face" style="float:left; width:42px; height:42px; ">
    <a href="Perfil.html"><span class="perfil">Perfil</span></a>
  </div>
</header>
<main>
<div class="biblioteca">
    <div class="abas">
        <div class="aba">Lendo</div>
        <div class="aba">Planejo Ler</div>
        <div class="aba">Lidos</div>
    </div>
    <input type="text" placeholder="Search..."class="search">
        <div class="livro-lista">

      <div class="livro-esquerda">
        <img src="https://m.media-amazon.com/images/I/81ibfYk4qmL.jpg" alt="Harry Potter">

        <div class="titulo">
          Harry Potter <br>e a Pedra Filosofal
        </div>
      </div>
    

    <div class="autor">
    J.K.Rowling
    </div>

    <div class="avaliacao">
    ☆ ☆ ☆ ☆ ☆
    </div>

    <div class="generos">
    Fantasia<br>
    Ação<br>
    Aventura<br>
    Drama<br>
    Comédia
    </div>
  </div>
   <div class="livro-lista">

      <div class="livro-esquerda">
        <a href="hungergames.html" class="link-livro"><img src="https://m.media-amazon.com/images/I/61I24wOsn8L._AC_UF1000,1000_QL80_.jpg" alt="Jogos Vorazes"></a>

        <div class="titulo">
          Jogos<br>
          Vorazes
        </div>
      </div>

      <div class="autor">
        Suzanne Collins
      </div>

      <div class="avaliacao">
        ☆ ☆ ☆ ☆
      </div>

      <div class="generos">
        Fantasia<br>
        Ficção Científica<br>
        Suspense
      </div>

    </div>

    <!-- Livro 3 -->
    <% livros.forEach(livro => { %>

    <div class="livro-lista" data-status="<%= livro.status %>">

      <!-- LADO ESQUERDO -->
      <div class="livro-esquerda">

        <img src="<%= livro.capa %>" alt="capa do livro">

        <div class="titulo">
          <%= livro.titulo %>
        </div>

      </div>

      <!-- AUTOR (se quiser adicionar depois no banco) -->
      <div class="autor">
        <%= livro.autor || "Autor desconhecido" %>
      </div>

      <!-- AVALIAÇÃO -->
      <div class="avaliacao">

        <% 
          const estrelas = Math.round(livro.nota || 0);
          for(let i = 0; i < 5; i++) {
        %>

          <span>
            <%= i < estrelas ? "★" : "☆" %>
          </span>

        <% } %>

      </div>

      <!-- GÊNEROS -->
      <div class="generos">

        <% livro.generos.forEach(genero => { %>

          <div>
            <%= genero %>
          </div>

        <% }) %>

      </div>

    </div>

  <% }) %>

</div>
</main>
<footer>
  <p class="footer">Desenvolvedores: Cauê e Alexandre</p>
</footer>
<script>
  function filtrar(status) {

  const livros = document.querySelectorAll(".livro-lista");
  const tabs = document.querySelectorAll(".aba");

  // troca aba ativa
  tabs.forEach(tab => tab.classList.remove("active"));
  event.target.classList.add("active");

  livros.forEach(livro => {

    const livroStatus = livro.dataset.status;

    if (status === "todos" || livroStatus === status) {
      livro.style.display = "block";
    } else {
      livro.style.display = "none";
    }

  });

}

// inicializa mostrando todos
window.onload = () => {
  filtrar("todos");
};

</script>
</body>
</html>